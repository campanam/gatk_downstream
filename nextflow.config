manifest {

	name = 'GATK Joint-Genotyping'
	author = 'Michael G. Campana'
	homePage = 'https://github.com/campanam/gatk_downstream'
	description = 'Automated GATK Joint-Genotyping'
	mainScript = 'gatk_downstream.nf'
	version = '0.1.0'
	nextflowVersion = '>=20.10.0'

}

params {

	outdir = "$launchDir/results"
	stem = "out"
	refseq = "ref.fa"
	refseq_fai = "ref.fa.fai"
	refseq_dict = "ref.dict"
	gvcfs = "$launchDir/gVCFs"
	java_options = '-D64 -Dserver -XX:MaxHeapSize=14G'
	vcftools_site_filters = "--minDP 5 --minGQ 40 --maxDP 125 --max-missing 0.5" // Site filters to pass to VCFtools. Set to "NULL" to ignore this filter.
	gatk_site_filters  = '--filter-name "filter" --filter-expression "QD < 4.0 || FS > 60.0 || MQ < 40.0 || SOR > 3.0 || ReadPosRankSum < 15 || MQRankSum < -2"' // Site filters to pass to GATK. Set to 'NULL' to ignore this filter.
	min_contig_length = 1 // Minimum length of contig (before filtering) to retain in analysis
	min_filt_contig_length = 1 // Minimum length of contig (after filtering) to retain in analysis
	email = "NULL" // Email to send completion status to. Set to "NULL" for no email.
	
}

conda.enabled = true

profiles {

	african {
	
		params {
			
			outdir = "$launchDir/african_results"
			stem = "african"
			refseq = "/scratch/nzp_ccg/refidx/loxAfr4.fa"
			refseq_fai = "/scratch/nzp_ccg/refidx/loxAfr4.fa.fai"
			refseq_dict = "/scratch/nzp_ccg/refidx/loxAfr4.dict"
		
		}
	
	}
	
	asian {
	
		params {
		
			outdir = "$launchDir/asian_results"
			stem = "asian"
			refseq = "/scratch/nzp_ccg/refidx/HiCKandula_yahs_scaffolds_final.fa"
			refseq_fai = "/scratch/nzp_ccg/refidx/HiCKandula_yahs_scaffolds_final.fa.fai"
			refseq_dict = "/scratch/nzp_ccg/refidx/HiCKandula_yahs_scaffolds_final.dict"
		
		}
	
	}

	standard {
	
		executor = 'local'
		
		process {
			errorStrategy = 'finish'
			maxRetries = 3
			
			withName: 'createGenomicsDB|jointGenotype|vcftoolsSiteFilter|gatkSiteFilter' {
				conda = 'bioconda::gatk4=4.3.0.0 bioconda::htslib=1.16 conda-forge::libzlib=1.2.13 bioconda::vcftools=0.1.16'
			}
			withName: 'sanityCheckLogsVcftools|sanityCheckLogsGatk' {
				conda = 'bioconda::bcftools=1.16 conda-forge::libzlib=1.2.13 conda-forge::gsl=2.7'
			}
		}
	}
	
	hydra {
	
		executor {
	
			name = 'sge'
			exitReadTimeout = '10min'
	
		}
	
		process {
			maxForks = 1000 // Prevent job submission overflow
			storeDir = 'chkpnt' // Prevent remaking completed files
			errorStrategy = 'finish'
			maxRetries = 3
			
			withName: extractChrNames {
				clusterOptions = '-l mres=1G,h_data=1G,h_vmem=1G -S /bin/bash'
				queue = 'sThC.q'
			}
			withName: 'createGenomicsDB|jointGenotype|gatkSiteFilter' {
				cpus = 2
				penv = 'mthread'
				clusterOptions = '-l mres=16G,h_data=16G,h_vmem=16G,himem -S /bin/bash'
				queue = 'mThM.q'
				conda = 'bioconda::gatk4=4.3.0.0 bioconda::htslib=1.16 conda-forge::libzlib=1.2.13 bioconda::vcftools=0.1.16'
			}
			withName: vcftoolsSiteFilter {
				cpus = 1
				queue = 'mThC.q'		
				clusterOptions = '-l mres=8G,h_data=8G,h_vmem=8G -S /bin/bash'
				conda = 'bioconda::gatk4=4.3.0.0 bioconda::htslib=1.16 conda-forge::libzlib=1.2.13 bioconda::vcftools=0.1.16'
			}
			withName: 'sanityCheckLogsVcftools|sanityCheckLogsGatk|concatenateVCFs' {
				conda = 'bioconda::bcftools=1.16 conda-forge::libzlib=1.2.13 conda-forge::gsl=2.7'
				queue = 'mThC.q'
				maxForks = 1000
				clusterOptions = '-l mres=8G,h_data=8G,h_vmem=8G -S /bin/bash'
			}
		}
	}
}
